# ===========================================
# .env для сервера — скопируйте в .env и заполните
# cp .env.example .env
# ===========================================

# --- PostgreSQL (в Docker: postgres:5432) ---
POSTGRES_USER=cleaning
POSTGRES_PASSWORD=cleaning_secret
POSTGRES_DB=cleaning_db
DATABASE_URL=postgresql://cleaning:cleaning_secret@postgres:5432/cleaning_db

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Backend ---
DEBUG=false
CORS_ORIGINS=http://localhost:3007,http://127.0.0.1:3007,http://frontend:3000
# Публичный URL API (для ссылок на аватары, фавиконку и т.д.)
API_BASE_URL=http://ВАШ_СЕРВЕР:8005
AVATARS_DIR=/app/data/avatars
FAVICON_DIR=/app/data/favicon

# --- Frontend ---
NODE_ENV=production
# Секрет для NextAuth (минимум 32 символа!)
AUTH_SECRET=change-this-in-production-min-32-chars
# Публичный URL сайта (для OAuth, cookies)
AUTH_URL=http://ВАШ_СЕРВЕР:3007
# URL бэкенда (внутри Docker: backend:8000)
BACKEND_URL=http://backend:8000

# --- Сайт (SEO, метаданные) ---
NEXT_PUBLIC_SITE_URL=http://ВАШ_СЕРВЕР:3007
NEXT_PUBLIC_COMPANY_PHONE=
NEXT_PUBLIC_COMPANY_EMAIL=

# --- OAuth (опционально) ---
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# YANDEX_CLIENT_ID=
# YANDEX_CLIENT_SECRET=
